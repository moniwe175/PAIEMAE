# ─── Supabase ────────────────────────────────────────────────────────────────
# URL do seu projeto Supabase (ex: https://abcdefgh.supabase.co)
SUPABASE_URL=

# Chave service_role (NÃO é a anon key!).
# Encontre em: Supabase Dashboard > Settings > API > service_role key
# ⚠️  NUNCA exponha esta chave no frontend — apenas backend/servidor.
SUPABASE_SERVICE_KEY=

# ─── WhatsApp (wppconnect-server) ───────────────────────────────────────────
# URL do wppconnect-server rodando localmente ou em container.
# Setup: https://github.com/wppconnect-team/wppconnect-server
WPP_SERVER_URL=http://localhost:21465

# Nome da sessão WhatsApp (aparece no painel do wppconnect).
WPP_SESSION_NAME=clinica-marketing

# Secret key configurada no wppconnect-server (config.json dele).
WPP_SECRET_KEY=

# Pasta onde o token da sessão fica salvo (QR Code persistente).
WPP_TOKEN_PATH=./config/tokens

# ─── Execução ───────────────────────────────────────────────────────────────
# DRY_RUN=true → nenhuma mensagem real é enviada, apenas logada.
# USE ISSO NA PRIMEIRA VEZ para validar sem mandar WhatsApp de verdade.
DRY_RUN=true

# Intervalo entre ciclos do scheduler (em minutos).
SCHEDULER_INTERVAL_MINUTES=30

# Fuso horário do scheduler.
TIMEZONE=America/Sao_Paulo
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_SERVICE_KEY=coloque-a-service-role-key-aqui

WPP_SERVER_URL=http://localhost:21465
WPP_SESSION_NAME=clinica-marketing
WPP_SECRET_KEY=troque-essa-chave-no-wppconnect-server
WPP_TOKEN_PATH=./config/tokens

DRY_RUN=true
SCHEDULER_INTERVAL_MINUTES=30
TIMEZONE=America/Sao_Paulo
