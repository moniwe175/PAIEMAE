SUPABASE_SERVICE_KEY=coloque-sua-service-role-key-aqui

# Pasta onde o Baileys salva os tokens de sessão (mantém sessão entre reinicializações)
AUTH_FOLDER=./auth_info_baileys

# Intervalo do polling em milissegundos (padrão: 30 segundos)
POLL_INTERVAL_MS=30000

# Janela máxima de atraso para mensagens críticas (padrão: 1 hora = 3600000ms)
MAX_EXPIRY_LAG_MS=3600000
